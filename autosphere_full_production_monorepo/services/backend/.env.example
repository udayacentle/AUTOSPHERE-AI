# JWT secret for auth
JWT_SECRET=AUTOSPHERE_SECRET

# Server port (default: 3000)
PORT=3000

# Frontend origin — local dev: Vite. Production EC2 .env: use your S3 website URL (OAuth redirects).
FRONTEND_ORIGIN=http://localhost:5173
# FRONTEND_ORIGIN=http://a-autosphere-ai.s3-website-us-east-1.amazonaws.com

# Google OAuth (optional). Callback must match this host:port.
GOOGLE_REDIRECT_URI=http://100.53.242.8:3000/auth/google/callback

# MongoDB (optional). If set, dashboard, profile, trips, etc. are stored in DB.
# Run "npm run seed" once to insert sample data.
# MONGODB_URI=mongodb://localhost:27017/autosphere
