# JWT secret for auth
JWT_SECRET=AUTOSPHERE_SECRET

# Server port (default: 3000)
PORT=3000

# Frontend origin (S3 website or CloudFront URL). Used for redirects/cookies where applicable.
# Example static website: http://a-autosphere-ai.s3-website-us-east-1.amazonaws.com
FRONTEND_ORIGIN=http://localhost:5173

# Google OAuth (optional). Callback must match this host:port.
GOOGLE_REDIRECT_URI=http://98.93.80.228:3000/auth/google/callback

# MongoDB (optional). If set, dashboard, profile, trips, etc. are stored in DB.
# Run "npm run seed" once to insert sample data.
# MONGODB_URI=mongodb://localhost:27017/autosphere
